# Environment — NEVER commit secrets
.env
.env.local
.env.*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Apple Sign In private key - NEVER commit this
keys/

# Capacitor — web assets are rebuilt by `cap sync`, no need to track
ios/App/App/public/
# CocoaPods lock (can be large and is reproducible)
ios/App/Pods/

# Secrets — NEVER commit API keys
ios/App/App/Secrets.plist
